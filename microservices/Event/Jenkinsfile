pipeline {
  agent any

  environment {
    SONAR_PROJECT_KEY  = 'piBackend-Event'
    SONAR_PROJECT_NAME = 'Skillio Backend - Event'
    MODULE_DIR         = 'microservices/Event'
    SONAR_HOST_URL     = 'http://192.168.33.10:9000'
  }

  stages {
    stage('1. Récupération du code depuis Git') {
      steps {
        echo 'Récupération du dépôt (checkout SCM)...'
        checkout scm

        dir("${env.MODULE_DIR}") {
          sh '''
            set -eu
            pwd
            test -f pom.xml
          '''
        }
        echo 'Code récupéré avec succès.'
      }
    }

    stage('2. Nettoyage et Compilation') {
      steps {
        echo 'Nettoyage et compilation du projet Maven...'
        echo 'Exécution des tests et génération du rapport JaCoCo...'
        dir("${env.MODULE_DIR}") {
          sh 'mvn -q -f pom.xml clean test -Dspring.profiles.active=test'
          sh 'test -f target/site/jacoco/jacoco.xml'
        }
        echo 'Nettoyage, compilation et tests terminés.'
      }
    }

    stage('3. Analyse SonarQube') {
      steps {
        echo 'Analyse de la qualité du code avec SonarQube...'
        dir("${env.MODULE_DIR}") {
          withSonarQubeEnv('SonarQube') {
            sh """
              rm -rf target/sonar
              mvn -q -f pom.xml sonar:sonar \\
                -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\
                -Dsonar.projectName="${SONAR_PROJECT_NAME}" \\
                -Dsonar.sources=src/main/java \\
                -Dsonar.tests=src/test/java \\
                -Dsonar.java.binaries=target/classes \\
                -Dsonar.junit.reportPaths=target/surefire-reports \\
                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
            """
          }
        }
        echo "Analyse SonarQube terminée — consultez les résultats sur: ${SONAR_HOST_URL}/dashboard?id=${SONAR_PROJECT_KEY}"
      }
    }

    stage('4. Génération du fichier JAR') {
      steps {
        echo 'Génération du fichier JAR...'
        dir("${env.MODULE_DIR}") {
          sh 'mvn -q -f pom.xml package -DskipTests'
        }
        echo 'Archivage du JAR généré...'
        archiveArtifacts artifacts: "${env.MODULE_DIR}/target/*.jar",
                         fingerprint: true,
                         allowEmptyArchive: false
        echo 'Fichier JAR généré avec succès.'
      }
    }

    stage('5. Lancer partie CD') {
      steps {
        script {
          def cdJob = "${env.JOB_NAME}-CD"
          echo "Lancement du pipeline CD: ${cdJob}"
          build job: cdJob,
                wait: false,
                propagate: false,
                parameters: [
                  booleanParam(name: 'DEPLOY', value: true),
                  booleanParam(name: 'INSTALL_OBSERVABILITY', value: false),
                  string(name: 'IMAGE_TAG', value: "${env.BUILD_NUMBER}")
                ]
        }
      }
    }
  }

  post {
    success {
      archiveArtifacts artifacts: "${env.MODULE_DIR}/target/site/jacoco/jacoco.xml",
                       fingerprint: true,
                       allowEmptyArchive: true
    }
    failure {
      archiveArtifacts artifacts: "${env.MODULE_DIR}/target/site/jacoco/**",
                       fingerprint: true,
                       allowEmptyArchive: true
    }
  }
}
